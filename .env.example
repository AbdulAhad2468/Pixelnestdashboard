# Environment Variables for Pixel Nest
# Copy this file to .env.local and fill in your values

# App Configuration
NEXT_PUBLIC_APP_NAME=Pixel Nest
NEXT_PUBLIC_APP_URL=http://pixelnestdashboard.vercel.app

# Admin Credentials (default admin user)
ADMIN_EMAIL=admin123@owner.com
ADMIN_PASSWORD=Jontigrid2024*

# Data Directory (relative to project root)
DATA_DIR=data

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/*,application/pdf,.doc,.docx,.txt

# Vercel Postgres Database
# For local development, use a connection string or leave empty
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
